# ==============================================
# PFOS — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to Git
# ==============================================

# Database (Neon Postgres)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-king-ajxevy0y-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_KEY"
CLERK_SECRET_KEY="sk_test_YOUR_KEY"

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# AI (Anthropic Claude)
ANTHROPIC_API_KEY="sk-ant-YOUR_KEY"

# Storage (Cloudflare R2)
R2_ACCOUNT_ID="YOUR_CLOUDFLARE_ACCOUNT_ID"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="pfos-documents"
R2_PUBLIC_URL="https://YOUR_BUCKET.r2.dev"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PFOS"
